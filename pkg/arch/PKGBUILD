# Maintainer: psyclyx
pkgname=snail
pkgver=0.10.0
pkgrel=1
pkgdesc='GPU font rendering via direct Bézier curve evaluation (Slug algorithm)'
arch=('x86_64')
url='https://github.com/psyclyx/snail'
license=('MIT')
depends=('libgl' 'harfbuzz' 'vulkan-loader')
makedepends=('zig>=0.16' 'pkg-config' 'shaderc' 'vulkan-headers')
source=("$pkgname-$pkgver.tar.gz::$url/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
    cd "$pkgname-$pkgver"
    XDG_CACHE_HOME="$srcdir/.cache" zig build \
        --release=fast \
        --prefix "$srcdir/install" \
        -Dtarget=native
}

package() {
    cd "$pkgname-$pkgver"

    install -Dm755 "$srcdir/install/lib/libsnail.so" "$pkgdir/usr/lib/libsnail.so"
    install -Dm644 "$srcdir/install/lib/libsnail.a" "$pkgdir/usr/lib/libsnail.a"
    install -d "$pkgdir/usr/include"
    install -m644 "$srcdir/install"/include/*.h "$pkgdir/usr/include/"
    install -Dm644 "$srcdir/install/lib/pkgconfig/snail.pc" "$pkgdir/usr/lib/pkgconfig/snail.pc"

    # license
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
